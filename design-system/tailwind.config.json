            "colors": {
                "brand": {
                    "primary": "#0D47A1", // Deep Teal - Trust & Calm
                    "success": "#00C853", // Resolution
                    "background": "#F8FAFC" // Anti-anxiety Neutral
                },
                "methodology": {
                    "needs": "#2979FF", // 50% - Essential
